---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Suborna Dash Tuli - Professional Female Voiceover Artist, Poetry Narrator, and Freelance Voice Talent." } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="keywords" content="Female Voiceover Artist, Poetry Narrator, Freelance Voice Talent, Audiobook Narration, Commercial VO" />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Noto+Serif+Bengali:wght@400;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
	</head>
	<body class="bg-cream text-charcoal font-sans antialiased selection:bg-gold selection:text-white">
		<slot />
	</body>
</html>