---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero';
import AudioGallery from '../components/AudioGallery';
import Services from '../components/Services';
import Pricing from '../components/Pricing';
import Testimonials from '../components/Testimonials';
import ContactForm from '../components/ContactForm';

// Fetch all markdown files from the services collection
const servicesFiles = Object.values(import.meta.glob('../content/services/*.md', { eager: true }));

const cleanServices = servicesFiles.map((file: any) => {
  return {
    title: file.frontmatter.title,
    icon: file.frontmatter.icon,
    body: file.rawContent ? file.rawContent().trim() : 'Service details.'
  };
});

// Fetch all audio tracks from audio collection
const audioFiles = Object.values(import.meta.glob('../content/audio/*.md', { eager: true }));

const audioTracks = audioFiles.map((file: any) => {
  return {
    id: file.frontmatter.id,
    label: file.frontmatter.label,
    platform: file.frontmatter.platform
  };
});

// Fetch all pricing plans from pricing collection
const pricingFiles = Object.values(import.meta.glob('../content/pricing/*.md', { eager: true }));

const pricingPlans = pricingFiles.map((file: any) => {
  return {
    title: file.frontmatter.title,
    price: file.frontmatter.price,
    description: file.frontmatter.description,
    featured: file.frontmatter.featured,
    features: file.frontmatter.features
  };
});
---

<Layout title="Suborna Dash Tuli | Professional Voiceover Artist & Poetry Narrator">
  <header class="fixed top-0 w-full z-50 bg-cream/80 backdrop-blur-md border-b border-gold/10 transition-all duration-300">
    <div class="container mx-auto px-6 py-4 flex justify-between items-center">
      <a href="#" class="text-2xl font-serif text-charcoal font-bold tracking-widest uppercase hover:text-gold transition-colors">
        <span class="text-gold">S</span>D<span class="text-gold">T</span>
      </a>
      <nav class="hidden md:flex gap-8 font-sans text-sm font-semibold tracking-widest uppercase text-charcoal/70">
        <a href="#demos" class="hover:text-gold transition-colors block py-2">Demos</a>
        <a href="#services" class="hover:text-gold transition-colors block py-2">Services</a>
        <a href="#contact" class="hover:text-gold transition-colors block py-2">Contact</a>
      </nav>
      <a href="#contact" class="px-6 py-2 bg-charcoal text-cream text-sm font-bold tracking-widest uppercase rounded-full hover:bg-gold transition-colors">
        Let's Talk
      </a>
    </div>
  </header>

  <main class="pt-20">
    <Hero />
    <AudioGallery tracks={audioTracks} client:visible />
    <Services services={cleanServices} />
    <Pricing plans={pricingPlans} />
    <Testimonials client:visible />
    <ContactForm client:visible />
  </main>

  <footer class="bg-charcoal text-cream/70 py-12 text-center font-sans">
    <div class="container mx-auto px-6">
      <div class="flex justify-center gap-8 mb-8">
        <a href="https://soundcloud.com/suborna-dash-tuli" target="_blank" rel="noopener noreferrer" class="hover:text-gold transition-colors block" aria-label="SoundCloud">
           <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 100 100">
             <path d="M97.1 57.6C97.1 66.8 89.6 74.3 80.3 74.3L38 74.3C36.8 74.3 35.8 73.3 35.8 72.1L35.8 30.6C35.8 30.3 35.9 30.1 36 29.8C42.8 19.3 53 14 62.4 14C74.6 14 84.7 23.3 85.8 35.3C92.2 36.8 97.1 42.6 97.1 49.6Z"/>
             <rect x="23.9" y="38.7" width="2.3" height="35.6" rx="1.1"/>
             <rect x="18.8" y="44.2" width="2.3" height="30.1" rx="1.1"/>
             <rect x="13.8" y="50" width="2.3" height="24.3" rx="1.1"/>
             <rect x="8.7" y="55" width="2.3" height="19.3" rx="1.1"/>
             <rect x="3.7" y="60.5" width="2.3" height="13.8" rx="1.1"/>
             <rect x="29" y="32" width="2.3" height="42.3" rx="1.1"/>
           </svg>
        </a>
        <a href="https://www.facebook.com/suborna.dashtuli/" target="_blank" rel="noopener noreferrer" class="hover:text-gold transition-colors block" aria-label="Facebook">
           <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" /></svg>
        </a>
        <a href="https://www.youtube.com/@suborna.dashtuli" target="_blank" rel="noopener noreferrer" class="hover:text-gold transition-colors block" aria-label="YouTube">
           <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M21.582 6.186a2.684 2.684 0 00-1.884-1.896C17.9 3.8 12 3.8 12 3.8s-5.9 0-7.698.49a2.684 2.684 0 00-1.884 1.896C2 7.9 2 12 2 12s0 4.1.418 5.814a2.684 2.684 0 001.884 1.896c1.798.49 7.698.49 7.698.49s5.9 0 7.698-.49a2.684 2.684 0 001.884-1.896C22 16.1 22 12 22 12s0-4.1-.418-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </a>
      </div>
      <div class="text-3xl font-serif text-cream font-bold tracking-widest uppercase mb-6 opacity-50">
        <span class="text-gold">S</span>uborna <span class="text-gold">D</span>ash <span class="text-gold">T</span>uli
      </div>
      <p class="text-sm font-light tracking-widest uppercase">&copy; {new Date().getFullYear()} Suborna Dash Tuli. All rights reserved.</p>
    </div>
  </footer>
</Layout>